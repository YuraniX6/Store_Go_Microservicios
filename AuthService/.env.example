# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_NAME=storego_auth
DB_USER=postgres
DB_PASSWORD=postgres

# JWT Configuration
# Base64 encoded secret key (minimum 32 characters)
# Example: YXV0aEtzZWNyZXRrZXlmb3JzdG9yZWdvbWljcm9zZXJ2aWNlYXV0aGVudGljYXRpb24=
JWT_SECRET=YXV0aEtzZWNyZXRrZXlmb3JzdG9yZWdvbWljcm9zZXJ2aWNlYXV0aGVudGljYXRpb24=

# Server Configuration
SERVER_PORT=8080

# Logging
LOG_LEVEL=INFO
